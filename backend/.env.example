# =====================================================================
# 이 파일은 커밋되는 템플릿입니다. 실제 키는 절대 여기에 적지 마세요.
# 실제 값은 같은 폴더의 .env (gitignored) 에 넣고 부팅하세요.
# =====================================================================

# DB (mysql 프로파일 사용 시)
DB_URL=jdbc:mysql://localhost:3306/diagnostic?useSSL=false&serverTimezone=Asia/Seoul
DB_USERNAME=diagnostic
DB_PASSWORD=change-me

# 외부 데이터 동기화 스케줄러 (시즌 단위). cron expr.
SYNC_CRON=0 0 4 * * *

# CORS 허용 오리진 (콤마 구분)
ALLOWED_ORIGINS=http://localhost:5173

# 대교협 (KCUE / 대학알리미) Open API 인증키
# 발급: https://www.academyinfo.go.kr (대학알리미 OpenAPI)
KCUE_API_KEY=
KCUE_API_BASE=https://www.academyinfo.go.kr/openApi
KCUE_SYNC_CRON=0 30 4 * * *

# 나이스 교육정보 (NEIS) Open API 인증키
# 발급: https://open.neis.go.kr
NEIS_API_KEY=
NEIS_API_BASE=https://open.neis.go.kr/hub
NEIS_SYNC_CRON=0 0 5 * * *

# US College Scorecard API 키 (data.gov)
# 발급: https://api.data.gov/signup/
SCORECARD_API_KEY=
SCORECARD_API_BASE=https://api.data.gov/ed/collegescorecard/v1
SCORECARD_SYNC_CRON=0 0 6 * * MON
# UNITID(IPEDS) 콤마 구분. 기본 = Harvard, MIT, Stanford, Princeton, Yale, Columbia, UChicago, UC Berkeley, UCLA, NYU
SCORECARD_SCHOOL_IDS=166027,166683,243744,186131,130794,190150,144050,110635,110662,193900

# 사용자 CSV 스테이징 디렉터리(절대경로 또는 backend 기준 상대)
DATA_STAGING_DIR=./data-staging

# Rate Limit (IP 기준)
RATELIMIT_PER_MINUTE=10
RATELIMIT_PER_HOUR=50
